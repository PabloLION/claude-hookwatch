{
  "name": "hookwatch",
  "version": "0.1.0",
  "description": "Claude Code plugin that logs all hook events to SQLite and serves a local web UI",
  "module": "src/cli/index.ts",
  "bin": {
    "hookwatch": "src/cli/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server/index.ts",
    "start": "bun src/server/index.ts",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun test && biome check ."
  },
  "dependencies": {
    "citty": "^0.2.1",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "bun-types": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
