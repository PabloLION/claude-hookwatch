{
  "name": "hookwatch",
  "version": "0.1.0",
  "description": "Claude Code plugin that logs all hook events to SQLite and serves a local web UI",
  "author": "Pablo LION",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PabloLION/claude-hookwatch.git"
  },
  "homepage": "https://github.com/PabloLION/claude-hookwatch",
  "keywords": [
    "claude-code",
    "hooks",
    "plugin",
    "observability",
    "sqlite",
    "bun"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src/",
    "hooks/",
    ".claude-plugin/",
    "LICENSE",
    "README.md"
  ],
  "module": "src/cli/index.ts",
  "bin": {
    "hookwatch": "src/cli/index.ts"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "check": "bun test src/ tests/handler-server.test.ts tests/smoke-http.test.ts && biome check .",
    "dev": "bun --watch src/server/index.ts",
    "format": "biome format --write .",
    "generate": "bun scripts/generate-plugin.ts",
    "lint": "biome check .",
    "probe:launcher": "bun scripts/claude-code-probes/probe-launcher.ts",
    "release": "bun scripts/release.ts",
    "start": "bun src/server/index.ts",
    "test": "bun test src/ tests/handler-server.test.ts tests/smoke-http.test.ts",
    "test:e2e": "playwright test tests/ui-e2e.test.ts",
    "test:smoke-browser": "playwright test tests/smoke-browser.test.ts",
    "test:smoke-http": "bun test tests/smoke-http.test.ts",
    "test:sse-e2e": "playwright test tests/sse-e2e.test.ts",
    "verify": "bun scripts/e2e-verify.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1",
    "@preact/signals": "^2.8.1",
    "citty": "^0.2.1",
    "htm": "^3.1.1",
    "open": "^11.0.0",
    "preact": "^10.28.4",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
